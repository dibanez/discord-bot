# =============================================================================
# Configuración del bot de ANFAIA — copia este archivo a .env y rellena valores.
# En Dokploy, pega estas variables en la pestaña "Environment" del proyecto.
# =============================================================================

# --- Discord ---
DISCORD_TOKEN=
LOG_CHANNEL_ID=
SUPPORT_CHANNEL_ID=

# --- Google Sheets ---
GOOGLE_SHEET_NAME=RegistroUsuariosANFAIA
GOOGLE_SHEET_TAB=usuarios
# Ruta del archivo de credenciales dentro del contenedor.
GOOGLE_CREDENTIALS_PATH=credentials.json
# Opción recomendada para Dokploy: pega aquí el contenido de credentials.json
# (JSON en una sola línea o codificado en base64). El bot lo escribe al arrancar.
# Si lo usas, no necesitas montar el archivo credentials.json.
GOOGLE_CREDENTIALS_JSON=

# --- Transcripción ---
# Proveedor por defecto: openai | voxtral | whisper
DEFAULT_TRANSCRIPTION_PROVIDER=openai
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
VOXTRAL_MODEL=voxtral-mini-latest
# Solo aplica si instalas el extra de Whisper local (no incluido en la imagen Docker).
WHISPER_MODEL=base

# --- Grabación de voz en vivo ---
# Activada: Discord forzó cifrado E2EE (DAVE, marzo 2026) y py-cord upstream aún no
# descifra el audio recibido (issue #3139), pero usamos el fork de vito1317 que sí lo
# hace (ver requirements.txt). Pon 'false' para desconectar la grabación sin tocar deps.
LIVE_RECORDING_ENABLED=true
# Segundos que el bot espera estando solo en un canal antes de auto-desconectarse.
ALONE_DISCONNECT_GRACE_SECONDS=60

# --- Subida a Google Drive ---
# Sube la transcripción (.md) y el audio a la carpeta anfaia/recordings del Drive
# de la cuenta de servicio (la misma de Google Sheets). Como esa cuenta sube a SU
# propio Drive, la carpeta 'anfaia' se comparte con DRIVE_SHARE_WITH para que sea
# visible en "Compartidos conmigo". Pon 'false' para desactivar la subida.
DRIVE_UPLOAD_ENABLED=true
DRIVE_SHARE_WITH=tu-email@gmail.com
# Opcionales:
# DRIVE_SHARE_ROLE=reader        # reader (ver/descargar) o writer
# DRIVE_FOLDER_PATH=anfaia/recordings

# --- Claves de API ---
# Necesaria para el proveedor 'openai' y para generar los resúmenes.
OPENAI_API_KEY=
# Necesaria para el proveedor 'voxtral'.
MISTRAL_API_KEY=

# --- Verificación ---
VERIFICATION_MAX_ATTEMPTS=3
COMUNIDAD_ROLE_NAME=Comunidad
